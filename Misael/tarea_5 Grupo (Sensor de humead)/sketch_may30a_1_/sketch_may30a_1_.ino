// FUNCIÓN QUE SE ENCARGA DE DIBUJAR LA FIGURA EN LA MATRIZ
void drawFigure(byte figura[8][8]) {
  for (int k = 2; k < 10; k++) {
    // ACTIVA LAS kUMNAS
    digitalWrite(k, LOW);
    // ACTIVA LAS DETERMINADAS FILAS
    for (int j = 9; j < 18; j++) {
      digitalWrite(k, figura[j][k]);
    }
  digitalWrite(k, HIGH);
  }
}

